<Window x:Class="POE_Part3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:POE_Part3"
        mc:Ignorable="d"
        Title="CyberGuard AI" Height="450" Width="800"
        Background="#1A1A2E">

    <Window.Resources>

        <!-- Dark navy button style -->
        <Style x:Key="NavyButton" TargetType="Button">
            <Setter Property="Background" Value="#0D3B8E"/>
            <Setter Property="Foreground" Value="#B8D4FF"/>
            <Setter Property="BorderBrush" Value="#2A6AEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A4AAA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0A2A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar menu button style -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0B0D0"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2040"/>
                                <Setter Property="BorderBrush" Value="#3A4A8A"/>
                                <Setter Property="Foreground" Value="#C8D8FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F1530"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exit button style (red tint) -->
        <Style x:Key="ExitButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D08080"/>
            <Setter Property="BorderBrush" Value="#4A1A1A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A1010"/>
                                <Setter Property="BorderBrush" Value="#8A2A2A"/>
                                <Setter Property="Foreground" Value="#FF9999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#11112A"/>
            <Setter Property="Foreground" Value="#C0C0D8"/>
            <Setter Property="BorderBrush" Value="#2A2A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#4A7AFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3A3A7A"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2A6AEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListView style -->
        <Style x:Key="DarkListView" TargetType="ListView">
            <Setter Property="Background" Value="#13132A"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C0C0D8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Quiz answer button style -->
        <Style x:Key="QuizButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A3A"/>
            <Setter Property="Foreground" Value="#A0B0D0"/>
            <Setter Property="BorderBrush" Value="#2A2A5A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E2A50"/>
                                <Setter Property="BorderBrush" Value="#3A5A9A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="#1A1A2E">

        <!--
            HOME GRID
            Main landing page with logo, welcome message, and proceed button.
        -->
        <Grid x:Name="home_grid" Visibility="Visible">

            <Rectangle Height="3" VerticalAlignment="Top" Fill="#0D3B8E"/>

            <Image
                Source="/logo.png"
                Height="200"
                Width="300"
                Margin="0,0,0,200"/>

            <TextBlock
                Text="Welcome to AI Cybersecurity Chatbot — click Continue to get started"
                Height="20"
                Width="350"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontFamily="Segoe UI"
                FontSize="13"
                Foreground="#8FA8D0"/>

            <Button
                Height="42"
                Width="220"
                Margin="0,200,0,0"
                Content="Proceed  →"
                Click="proceed"
                Style="{StaticResource NavyButton}"/>

        </Grid>


        <!--
            USERNAME GRID
            Prompts user to enter a username before entering the app.
        -->
        <Grid x:Name="username_grid" Visibility="Hidden">

            <Rectangle Height="3" VerticalAlignment="Top" Fill="#0D3B8E"/>

            <Image
                Source="/logo.png"
                Height="200"
                Width="300"
                Margin="0,0,0,200"/>

            <TextBlock
                Text="Enter your username to continue"
                Height="20"
                Width="270"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontFamily="Segoe UI"
                FontSize="13"
                Foreground="#8FA8D0"/>

            <TextBox
                Height="42"
                Width="270"
                Margin="0,100,0,0"
                FontFamily="Segoe UI"
                x:Name="usernames_input"
                Style="{StaticResource DarkTextBox}"/>

            <TextBlock
                Text="Please enter a username to continue..."
                Height="20"
                Width="270"
                TextAlignment="Center"
                Margin="0,180,0,0"
                Foreground="#FF6B6B"
                FontFamily="Segoe UI"
                FontSize="12"/>

            <Button
                Height="42"
                Width="270"
                Margin="0,250,0,0"
                Content="Submit username"
                Click="submit_name"
                Style="{StaticResource NavyButton}"/>

        </Grid>


        <!--
            MAIN APP GRID
            Contains the sidebar menu and all page panels.
        -->
        <Grid Height="450" Width="800"
              x:Name="MainPage"
              Visibility="Hidden"
              Background="#1A1A2E">

            <!-- Right-side sidebar -->
            <Grid Margin="595,0,0,0"
                  Background="#0F0F1A"
                  Width="215">

                <Rectangle Height="3" VerticalAlignment="Top" Fill="#0D3B8E"/>

                <StackPanel Background="Transparent"
                            Width="175"
                            Margin="0,10,10,0">

                    <TextBlock Text="Menu"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"
                               FontFamily="Segoe UI"
                               Margin="10,8,0,16"/>

                    <Rectangle Height="1" Fill="#1E1E3A" Margin="0,0,0,10"/>

                    <Button Content="💬  Chats"          Margin="0,4" Height="40" Click="chatting"  Style="{StaticResource SidebarButton}"/>
                    <Button Content="📋  Task Reminders" Margin="0,4" Height="40" Click="reminders" Style="{StaticResource SidebarButton}"/>
                    <Button Content="📜  Activity Log"   Margin="0,4" Height="40" Click="activity"  Style="{StaticResource SidebarButton}"/>
                    <Button Content="🎮  Game"            Margin="0,4" Height="40" Click="game"      Style="{StaticResource SidebarButton}"/>

                    <Rectangle Height="1" Fill="#1E1E3A" Margin="0,14,0,10"/>

                    <Button Content="✕  Exit"            Margin="0,0" Height="40" Click="exit"      Style="{StaticResource ExitButton}"/>

                </StackPanel>
            </Grid>


            <!-- ===== CHAT PAGE ===== -->
            <Grid Margin="0,0,205,0"
                  x:Name="chat_page"
                  Visibility="Visible"
                  Background="#1A1A2E">

                <Border Height="36" VerticalAlignment="Top"
                        Background="#0F0F1A"
                        BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                    <TextBlock Text="💬  Chat"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"/>
                </Border>

                <ListView Margin="14,44,14,101"
                          x:Name="chats"
                          Style="{StaticResource DarkListView}"/>

                <TextBox Margin="14,356,110,44"
                         x:Name="question"
                         Height="50"
                         Style="{StaticResource DarkTextBox}"/>

                <Button Content="Ask"
                        Click="send"
                        Height="50"
                        Margin="470,357,14,43"
                        Style="{StaticResource NavyButton}"/>
            </Grid>


            <!-- ===== REMINDERS PAGE ===== -->
            <Grid Margin="0,0,205,0"
                  x:Name="reminderPage"
                  Visibility="Hidden"
                  Background="#1A1A2E">

                <Border Height="36" VerticalAlignment="Top"
                        Background="#0F0F1A"
                        BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                    <TextBlock Text="📋  Task Reminders"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"/>
                </Border>

                <ListView Margin="14,44,14,87"
                          MouseDoubleClick="remind_append_MouseDoubleClick"
                          x:Name="view_tasks"
                          Style="{StaticResource DarkListView}"/>

                <TextBlock Text="Tasks and their status are listed above. Double-click to mark done, double-click again to delete once done."
                           TextAlignment="Center"
                           Margin="14,368,14,36"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FF6B6B"/>
            </Grid>


            <!-- ===== HISTORY PAGE ===== -->
            <Grid Margin="0,0,205,0"
                  x:Name="HistoryPage"
                  Visibility="Hidden"
                  Background="#1A1A2E">

                <Border Height="36" VerticalAlignment="Top"
                        Background="#0F0F1A"
                        BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                    <TextBlock Text="🗂️  Interest History"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"/>
                </Border>

                <ListView Margin="14,44,14,87"
                          MouseDoubleClick="remind_append_MouseDoubleClick"
                          x:Name="history_append"
                          Style="{StaticResource DarkListView}"/>

                <TextBlock Text="No history yet? Head to Chats and say 'I am interested in...' to save topics here."
                           TextAlignment="Center"
                           Margin="14,368,14,36"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FF6B6B"/>
            </Grid>


            <!-- ===== ACTIVITY LOG PAGE ===== -->
            <Grid Margin="0,0,205,0"
                  x:Name="LogPage"
                  Visibility="Hidden"
                  Background="#1A1A2E">

                <Border Height="36" VerticalAlignment="Top"
                        Background="#0F0F1A"
                        BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                    <TextBlock Text="📜  Activity Log"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"/>
                </Border>

                <ListView Margin="14,44,14,87"
                          MouseDoubleClick="remind_append_MouseDoubleClick"
                          x:Name="log_append"
                          Style="{StaticResource DarkListView}"/>

                <TextBlock Text="All app activity is recorded here as you use the chatbot."
                           TextAlignment="Center"
                           Margin="14,368,14,36"
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI"
                           FontSize="11"
                           Foreground="#FF6B6B"/>
            </Grid>


            <!-- ===== GAME / QUIZ PAGE ===== -->
            <Grid Margin="0,0,205,0"
                  x:Name="gamePage"
                  Visibility="Hidden"
                  Background="#1A1A2E">

                <Border Height="36" VerticalAlignment="Top"
                        Background="#0F0F1A"
                        BorderBrush="#1E1E3A" BorderThickness="0,0,0,1">
                    <TextBlock Text="🎮  Cybersecurity Quiz"
                               VerticalAlignment="Center"
                               Margin="16,0"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7A9FFF"/>
                </Border>

                <Grid Height="390"
                      x:Name="quizGame_page"
                      Visibility="Visible"
                      Margin="10,40,10,10">

                    <TextBlock Height="50"
                               Width="340"
                               Text="Question"
                               Foreground="#7AB8FF"
                               TextAlignment="Center"
                               FontSize="15"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               x:Name="question_asked"
                               Margin="0,0,0,210"/>

                    <TextBlock Height="60"
                               Width="100"
                               Text="Score"
                               Foreground="#4A7AFF"
                               TextAlignment="Center"
                               FontSize="18"
                               FontFamily="Segoe UI"
                               FontWeight="Bold"
                               Margin="-2,6,477,324"
                               x:Name="score_count"/>

                    <Button Height="40" Width="270" Margin="0,0,290,120"
                            x:Name="optionButtonOne"
                            Click="optionSelected"
                            Style="{StaticResource QuizButton}"/>

                    <Button Height="40" Width="270" Margin="290,0,0,120"
                            x:Name="optionButtonTwo"
                            Click="optionSelected"
                            Style="{StaticResource QuizButton}"/>

                    <Button Height="40" Width="270" Margin="0,0,290,0"
                            x:Name="optionButtonThree"
                            Click="optionSelected"
                            Style="{StaticResource QuizButton}"/>

                    <Button Height="40" Width="270" Margin="290,0,0,0"
                            x:Name="optionButtonFour"
                            Click="optionSelected"
                            Style="{StaticResource QuizButton}"/>

                    <Button Height="38" Width="120"
                            Background="#8E0D0D"
                            Content="Submit Answer"
                            Foreground="#FFB8B8"
                            HorizontalContentAlignment="Center"
                            Margin="0,140,0,0"
                            Click="answerButton"
                            FontFamily="Segoe UI"
                            FontSize="12"/>

                </Grid>
            </Grid>

        </Grid>

    </Grid>
</Window>